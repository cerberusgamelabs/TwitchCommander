{
  "name": "twitchcommander",
  "version": "1.3.0",
  "description": "Run things locally controlled by Twitch commands.",
  "main": "app/electron/gui.js",
  "scripts": {
    "setup": "node install.js",
    "test": "clear",
    "start": "electron .",
    "dist": "node scripts/prepare-packaged-runtime.js && electron-builder --win portable && node scripts/prepare-portable-dist.js"
  },
  "keywords": [
    "twitch",
    "chat"
  ],
  "author": "Liliana Kilroy (yggdrassoftgaming@gmail.com)",
  "license": "ISC",
  "dependencies": {
    "@paymoapp/active-window": "^2.1.4",
    "bindings": "^1.5.0",
    "child_process": "^1.0.2",
    "clipboardy": "^2.3.0",
    "fs": "^0.0.1-security",
    "jimp": "^0.22.10",
    "node-abort-controller": "^3.1.1",
    "node-gyp-build": "^4.8.4",
    "obs-websocket-js": "^5.0.2",
    "ps-list": "^8.1.1",
    "tmi.js": "^1.8.5",
    "twitch-js": "^2.0.0-beta.45",
    "twurple": "^1.0.0",
    "window": "^4.2.7"
  },
  "devDependencies": {
    "electron": "^23.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.cerberusgamelabs.twitchcommander",
    "productName": "TwitchCommander",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/**/.git/**/*",
      "!node_modules/**/node_modules/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "TwitchCommander-${version}.${ext}"
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false
  }
}
